<% layout("layout/boilerplate.ejs") %>

<div class="container mt-4">

    <!-- TOP HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Job Portal
        </h2>

        <div>

            <!-- SIDEBAR BUTTON -->
            <button
                class="btn btn-dark me-2"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#profileSidebar"
            >
                ☰ Profile
            </button>

            <a href="/" class="btn btn-outline-primary">
                Dashboard
            </a>

            <a href="/logout" class="btn btn-outline-danger">
                Logout
            </a>

        </div>

    </div>

    <!-- SEARCH BAR -->
    <form action="/" method="GET" class="d-flex mb-4">

        <input
            type="text"
            name="q"
            class="form-control me-2"
            placeholder="Search jobs..."
        >

        <button class="btn btn-primary">
            Search
        </button>

    </form>

    <!-- JOB LIST -->
    <h3 class="mb-3">Job Listings</h3>

    <% if (jobs.length === 0) { %>

        <div class="alert alert-warning">
            No jobs found 
        </div>

    <% } %>

    <div class="row">

        <% jobs.forEach(job => { %>

            <div class="col-md-6 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <!-- JOB TITLE -->
                        <h5 class="text-primary">
                            <%= job.title %>
                        </h5>

                        <!-- COMPANY -->
                        <p class="mb-1">
                            <strong>🏢 Company:</strong>
                            <%= job.company_name %>
                        </p>

                        <!-- LOCATION -->
                        <p class="mb-2">
                            <strong>📍 Location:</strong>
                            <%= job.location %>
                        </p>

                        <!-- DESCRIPTION -->
                        <p class="text-muted small">
                            <%= job.description?.slice(0, 120) %>...
                        </p>

                        <!-- APPLY BUTTON -->
                        <a
                            href="<%= job.url %>"
                            target="_blank"
                            class="btn btn-success btn-sm"
                        >
                            🚀 Apply Now
                        </a>

                        <!-- LIKE BUTTON -->
                        <form action="/toggle-like" method="POST" class="mt-2">

                            <input type="hidden" name="title" value="<%= job.title %>">
                            <input type="hidden" name="company" value="<%= job.company_name %>">
                            <input type="hidden" name="location" value="<%= job.location %>">
                            <input type="hidden" name="description" value="<%= job.description %>">
                            <input type="hidden" name="applyLink" value="<%= job.url %>">

                            <button class="btn btn-outline-danger btn-sm">
                                ❤️ Like
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<!-- ========================= -->
<!-- PROFILE SIDEBAR -->
<!-- ========================= -->

<div
    class="offcanvas offcanvas-start"
    tabindex="-1"
    id="profileSidebar"
>
    <a href="/profile/edit" class="btn btn-warning btn-sm mt-3 w-10">
     ➕ Add Details
   </a>
   
    <!-- HEADER -->
    <div class="offcanvas-header border-bottom flex-column text-center">

        <!-- PROFILE IMAGE -->
        <img
            src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
            class="rounded-circle mb-3"
            width="90"
            height="90"
        >

        <!-- USERNAME -->
        <h4 class="fw-bold mb-0">
            <%= user.username %>
        </h4>

        <!-- EMAIL -->
        <small class="text-muted mb-3">
            <%= user.email %>
        </small>

        <button
            type="button"
            class="btn-close position-absolute top-0 end-0 m-3"
            data-bs-dismiss="offcanvas"
        ></button>

    </div>

    <!-- BODY -->
    <div class="offcanvas-body">

        <!-- PROFILE -->
        <div class="card mb-3 shadow-sm">

            <div class="card-body">

                <h6 class="text-primary">
                     Profile
                </h6>

                <p class="mb-0">
                    <%= user.profile || "No profile added" %>
                </p>

            </div>

        </div>

        <!-- SKILLS -->
        <div class="card mb-3 shadow-sm">

            <div class="card-body">

                <h6 class="text-primary">
                    🛠 Skills
                </h6>

                <p class="mb-0">
                    <%= user.skills || "No skills added" %>
                </p>

            </div>

        </div>

        <!-- EDUCATION -->
        <div class="card mb-3 shadow-sm">

            <div class="card-body">

                <h6 class="text-primary">
                    🎓 Education
                </h6>

               <p class="mb-1">
                      <strong>Degree:</strong>
                      <%= user.education?.degree %>
                    </p>

                    <p class="mb-1">
                      <strong>College:</strong>
                      <%= user.education?.college %>
                    </p>

                    <p class="mb-0">
                      <strong>Year:</strong>
                      <%= user.education?.year %>
                    </p>

            </div>
          <!-- RESUME SCORE -->


       
            <div class="mt-3">
    <a href="<%= user.resume %>" 
       target="_blank" 
       class="btn btn-primary">
       <i class="bi bi-file-earmark-pdf"></i> View Resume
    </a>
</div>
        </div>

    </div>

</div>